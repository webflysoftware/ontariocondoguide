# One-time setup on hh3 (adjust deploy user if needed):
#   sudo visudo -f /etc/sudoers.d/ontariocondoguide
#
# Replace DEPLOY_USER with the SSH user used by GitHub Actions.

DEPLOY_USER ALL=(root) NOPASSWD: /bin/mkdir -p /var/www/ontariocondoguide
DEPLOY_USER ALL=(root) NOPASSWD: /bin/cp /tmp/ontariocondoguide.nginx /etc/nginx/sites-available/ontariocondoguide
DEPLOY_USER ALL=(root) NOPASSWD: /bin/ln -sf /etc/nginx/sites-available/ontariocondoguide /etc/nginx/sites-enabled/ontariocondoguide
DEPLOY_USER ALL=(root) NOPASSWD: /usr/sbin/nginx -t
DEPLOY_USER ALL=(root) NOPASSWD: /bin/systemctl reload nginx
