---
interface Props {
  title: string;
  items: { label: string; href: string }[];
}

const { title, items } = Astro.props;
---

{
  items.length > 0 && (
    <section class="my-8">
      <h2 class="mb-3 text-lg font-semibold text-slate-900">{title}</h2>
      <ul class="space-y-2 text-sm">
        {items.map((item) => (
          <li>
            <a href={item.href} class="text-brand-700">{item.label}</a>
          </li>
        ))}
      </ul>
    </section>
  )
}
