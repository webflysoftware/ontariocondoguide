---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<nav
  aria-label="Table of contents"
  class:list={['rounded-lg border border-border bg-slate-50 p-5', className]}
  data-toc
>
  <p class="text-sm font-semibold text-slate-900">On this page</p>
  <ol class="mt-3 space-y-2 text-sm" data-toc-list>
    <li class="text-muted">Loading…</li>
  </ol>
</nav>

<script>
  function slugify(text: string): string {
    return text
      .toLowerCase()
      .replace(/[^\w\s-]/g, '')
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-')
      .trim();
  }

  function buildToc() {
    const article = document.querySelector('article[data-pagefind-body]');
    const tocList = document.querySelector('[data-toc-list]');
    if (!article || !tocList) return;

    const headings = article.querySelectorAll('h2, h3');
    if (headings.length === 0) {
      tocList.closest('[data-toc]')?.remove();
      return;
    }

    tocList.innerHTML = '';

    headings.forEach((heading) => {
      if (!(heading instanceof HTMLHeadingElement)) return;

      if (!heading.id) {
        heading.id = slugify(heading.textContent ?? 'section');
      }

      const li = document.createElement('li');
      if (heading.tagName === 'H3') {
        li.className = 'ml-4';
      }

      const link = document.createElement('a');
      link.href = `#${heading.id}`;
      link.textContent = heading.textContent;
      link.className = 'text-slate-700 no-underline hover:text-brand-700 hover:underline';

      li.appendChild(link);
      tocList.appendChild(li);
    });
  }

  buildToc();
</script>
