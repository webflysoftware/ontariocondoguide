---
import { Image } from 'astro:assets';
import heroImage from '../assets/images/ontario-board-agm.png';
import { SITE } from '../lib/site';

const quickLinks = [
  { href: '/guides', label: 'Guides' },
  { href: '/templates', label: 'Templates' },
  { href: '/tools', label: 'Tools' },
  { href: '/glossary', label: 'Glossary' },
];
---

<section class="relative isolate overflow-hidden bg-slate-900">
  <div class="absolute inset-0" aria-hidden="true">
    <Image
      src={heroImage}
      alt=""
      class="h-full w-full object-cover object-center"
      widths={[640, 960, 1280, 1920]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div
      class="absolute inset-0 bg-gradient-to-r from-slate-950/92 via-slate-900/78 to-slate-900/45 sm:via-slate-900/72"
    >
    </div>
    <div class="absolute inset-0 bg-gradient-to-t from-slate-950/55 via-transparent to-slate-950/25">
    </div>
  </div>

  <div
    class="relative mx-auto flex min-h-[20rem] max-h-[34rem] max-w-6xl flex-col justify-center px-4 py-12 sm:min-h-[24rem] sm:px-6 sm:py-14 md:min-h-[28rem] md:py-16 lg:min-h-[30rem]"
  >
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-100/90 sm:text-sm">
      Independent educational resource
    </p>
    <h1
      class="mt-2 max-w-3xl text-3xl font-bold tracking-tight text-white sm:text-4xl md:text-[2.75rem] md:leading-tight"
    >
      Practical Ontario condo governance resources
    </h1>
    <p class="mt-3 max-w-2xl text-base leading-7 text-slate-200 sm:mt-4 sm:text-lg sm:leading-8">
      {SITE.name} helps boards, owners, and property managers understand AGMs, elections, proxies,
      quorum, and meeting planning — with clear guides, templates, and tools.
    </p>

    <nav aria-label="Primary sections" class="mt-6 flex flex-wrap gap-2 sm:mt-8 sm:gap-3">
      {
        quickLinks.map((link) => (
          <a
            href={link.href}
            class="rounded-md border border-white/20 bg-white/10 px-3 py-2 text-sm font-medium text-white no-underline backdrop-blur-sm transition hover:border-white/35 hover:bg-white/15 sm:px-4"
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</section>
