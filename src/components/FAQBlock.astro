---
interface Props {
  faqs: { question: string; answer: string }[];
}

const { faqs } = Astro.props;
---

{
  faqs.length > 0 && (
    <section class="my-10">
      <h2 class="mb-4 text-2xl font-semibold">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="rounded-lg border border-border bg-slate-50 p-4">
            <summary class="cursor-pointer font-medium text-slate-900">{faq.question}</summary>
            <p class="mt-3 text-sm leading-6 text-slate-700">{faq.answer}</p>
          </details>
        ))}
      </div>
    </section>
  )
}
