---
interface Props {
  title: string;
  description: string;
  href: string;
}

const { title, description, href } = Astro.props;
---

<section class="rounded-lg border border-brand-100 bg-brand-50 p-5">
  <h2 class="text-base font-semibold text-brand-800">{title}</h2>
  <p class="mt-2 text-sm leading-6 text-slate-700">{description}</p>
  <a href={href} class="mt-3 inline-block text-sm font-medium text-brand-700 no-underline hover:underline">
    Learn more
  </a>
</section>
