---
interface Props {
  title: string;
  description: string;
  href: string;
}

const { title, description, href } = Astro.props;
---

<section class="rounded-xl border border-brand-200 bg-gradient-to-br from-brand-50 to-white p-6 shadow-sm">
  <h2 class="text-lg font-semibold text-brand-900">{title}</h2>
  <p class="mt-2 text-sm leading-6 text-slate-700">{description}</p>
  <a
    href={href}
    class="mt-4 inline-flex items-center rounded-md bg-brand-700 px-4 py-2 text-sm font-medium text-white no-underline hover:bg-brand-800"
  >
    Learn more →
  </a>
</section>
