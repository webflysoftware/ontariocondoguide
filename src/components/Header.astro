---
import { NAV_LINKS, SITE } from '../lib/site';
---

<header class="border-b border-border bg-white">
  <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-4 py-4 sm:px-6">
    <a href="/" class="no-underline">
      <span class="block text-lg font-semibold text-slate-900">{SITE.name}</span>
      <span class="block text-sm text-muted">{SITE.tagline}</span>
    </a>
    <nav aria-label="Main navigation">
      <ul class="flex flex-wrap gap-x-4 gap-y-2 text-sm font-medium">
        {
          NAV_LINKS.map((link) => (
            <li>
              <a href={link.href} class="text-slate-700 no-underline hover:text-brand-700">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
