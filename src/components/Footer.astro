---
import { FOOTER_LINKS, SITE } from '../lib/site';
---

<footer class="mt-16 border-t border-border bg-slate-50">
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <div class="grid gap-8 md:grid-cols-2">
      <div>
        <p class="text-lg font-semibold text-slate-900">{SITE.name}</p>
        <p class="mt-2 max-w-md text-sm leading-6 text-slate-600">{SITE.tagline}</p>
        <p class="mt-4 max-w-md text-sm leading-6 text-slate-600">{SITE.disclaimer}</p>
      </div>
      <nav aria-label="Footer navigation">
        <ul class="grid grid-cols-2 gap-x-4 gap-y-2 text-sm">
          {
            FOOTER_LINKS.map((link) => (
              <li>
                <a href={link.href} class="text-slate-700 no-underline hover:text-brand-700">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
    <p class="mt-8 text-xs text-muted">
      &copy; {new Date().getFullYear()} {SITE.name}. All rights reserved.
    </p>
  </div>
</footer>
