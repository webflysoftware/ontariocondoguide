---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  path: string;
  heading?: string;
  schema?: object | object[];
}

const { title, description, path, heading, schema } = Astro.props;
---

<BaseLayout title={title} description={description} path={path} schema={schema}>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    {heading && <h1 class="mb-4 text-3xl font-bold sm:text-4xl">{heading}</h1>}
    <slot />
  </div>
</BaseLayout>
