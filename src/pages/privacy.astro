---
import LandingPageLayout from '../layouts/LandingPageLayout.astro';
---

<LandingPageLayout
  title="Privacy Policy"
  description="Privacy policy placeholder for Ontario Condo Guide."
  path="/privacy"
  heading="Privacy Policy"
>
  <div class="prose max-w-2xl">
    <p>
      This is a placeholder privacy policy suitable for an MVP informational website. A full policy
      will be published before collecting personal information at scale.
    </p>
    <h2>Information we may collect</h2>
    <p>
      If you use the contact form in the future, we may collect your name, email address, role,
      topic, and message content so we can respond.
    </p>
    <h2>Analytics</h2>
    <p>
      We may use privacy-conscious analytics in production to understand site usage. Details will be
      updated here when enabled.
    </p>
    <h2>Questions</h2>
    <p>
      For privacy questions, use the <a href="/contact">contact page</a>.
    </p>
  </div>
</LandingPageLayout>
