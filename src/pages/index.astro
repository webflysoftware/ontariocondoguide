---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeHero from '../components/HomeHero.astro';
import FeaturedGuideCard from '../components/FeaturedGuideCard.astro';
import ArticleCard from '../components/ArticleCard.astro';
import CategoryCard from '../components/CategoryCard.astro';
import TopicPillar from '../components/TopicPillar.astro';
import DisclaimerBox from '../components/DisclaimerBox.astro';
import CTABox from '../components/CTABox.astro';
import SearchBox from '../components/SearchBox.astro';
import { SITE, CATEGORIES, CATEGORY_META } from '../lib/site';
import { resolveCoverImage } from '../lib/coverImages';
import {
  contentPath,
  getPublishedGuides,
  getPublishedTemplates,
  getPublishedTools,
  getPublishedGlossary,
  slugFromEntry,
} from '../lib/content';

const guides = await getPublishedGuides();
const templates = await getPublishedTemplates();
const tools = await getPublishedTools();
const glossary = await getPublishedGlossary();

const spotlightGuide = guides.find((guide) => guide.data.featured);
const spotlightSlug = spotlightGuide ? slugFromEntry(spotlightGuide) : undefined;
const spotlightImage = spotlightGuide ? resolveCoverImage(spotlightGuide.data.coverImage) : undefined;

const featuredGuides = guides
  .filter((guide) => slugFromEntry(guide) !== spotlightSlug)
  .slice(0, 3);
const featuredTemplates = templates.slice(0, 2);
const featuredTools = tools.slice(0, 3);

const categoryCounts = CATEGORIES.reduce<Record<string, number>>((acc, cat) => {
  acc[cat] = guides.filter((g) => g.data.category === cat).length;
  return acc;
}, {});

const pillars = [
  {
    title: 'AGM planning',
    description: 'Prepare notices, agendas, quorum, and owner participation for annual general meetings.',
    href: '/guides/ontario-condo-agm-guide',
    guides: [
      { label: 'Ontario Condo AGM Guide', href: '/guides/ontario-condo-agm-guide' },
      { label: 'How to Prepare for a Condo AGM', href: '/guides/how-to-prepare-condo-agm' },
      { label: 'AGM Checklist', href: '/templates/agm-checklist' },
    ],
  },
  {
    title: 'Board elections',
    description: 'Run fair director elections with clear nominations, voting, and results.',
    href: '/guides/ontario-condo-board-elections',
    guides: [
      { label: 'Board Election Guide', href: '/guides/ontario-condo-board-elections' },
      { label: 'How Elections Usually Work', href: '/guides/how-condo-board-elections-work' },
      { label: 'Election Checklist', href: '/templates/condo-election-checklist' },
    ],
  },
  {
    title: 'Proxies & quorum',
    description: 'Track participation, manage proxy forms, and avoid quorum failures.',
    href: '/guides/ontario-condo-quorum',
    guides: [
      { label: 'Quorum Guide', href: '/guides/ontario-condo-quorum' },
      { label: 'Proxy Form Guide', href: '/guides/ontario-condo-proxy-form' },
      { label: 'Quorum Calculator', href: '/tools/quorum-calculator' },
    ],
  },
];
---

<BaseLayout title={SITE.name} description={SITE.description} path="/">
  <HomeHero />

  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <SearchBox />

    <div class="mt-8 flex flex-wrap gap-6 rounded-xl border border-border bg-slate-50 px-6 py-5 text-sm">
      <div>
        <span class="text-2xl font-bold text-brand-800">{guides.length}</span>
        <span class="ml-2 text-slate-600">guides</span>
      </div>
      <div>
        <span class="text-2xl font-bold text-brand-800">{templates.length}</span>
        <span class="ml-2 text-slate-600">templates</span>
      </div>
      <div>
        <span class="text-2xl font-bold text-brand-800">{tools.length}</span>
        <span class="ml-2 text-slate-600">tools</span>
      </div>
      <div>
        <span class="text-2xl font-bold text-brand-800">{glossary.length}</span>
        <span class="ml-2 text-slate-600">glossary terms</span>
      </div>
    </div>

    {
      spotlightGuide && spotlightImage && (
        <FeaturedGuideCard
          title={spotlightGuide.data.title}
          href={contentPath('guides', slugFromEntry(spotlightGuide))}
          summary={spotlightGuide.data.summary}
          category={spotlightGuide.data.category}
          image={spotlightImage}
          imageAlt={spotlightGuide.data.coverImageAlt ?? spotlightGuide.data.title}
        />
      )
    }

    <section class="mt-12">
      <h2 class="text-2xl font-semibold">Explore by topic</h2>
      <p class="mt-2 max-w-2xl text-slate-600">
        Browse resources organized around the governance topics Ontario condo boards, owners, and
        managers deal with most often.
      </p>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          CATEGORIES.filter((cat) => cat !== 'Templates & Tools').map((category) => (
            <CategoryCard
              title={category}
              description={CATEGORY_META[category].description}
              href={CATEGORY_META[category].indexPath}
              count={categoryCounts[category]}
            />
          ))
        }
        <CategoryCard
          title="Templates & Tools"
          description={CATEGORY_META['Templates & Tools'].description}
          href="/templates"
          count={templates.length + tools.length}
        />
      </div>
    </section>

    <section class="mt-14">
      <h2 class="text-2xl font-semibold">Start with a topic pillar</h2>
      <div class="mt-6 grid gap-6 lg:grid-cols-3">
        {pillars.map((pillar) => <TopicPillar {...pillar} />)}
      </div>
    </section>

    <section class="mt-14 grid gap-8 lg:grid-cols-3">
      <div>
        <div class="mb-4 flex items-center justify-between">
          <h2 class="text-xl font-semibold">Popular guides</h2>
          <a href="/guides" class="text-sm font-medium no-underline">View all</a>
        </div>
        <div class="space-y-4">
          {
            featuredGuides.map((guide) => (
              <ArticleCard
                title={guide.data.title}
                href={contentPath('guides', slugFromEntry(guide))}
                summary={guide.data.summary}
                category={guide.data.category}
                meta={`Updated ${guide.data.lastUpdated.toLocaleDateString('en-CA')}`}
              />
            ))
          }
        </div>
      </div>

      <div>
        <div class="mb-4 flex items-center justify-between">
          <h2 class="text-xl font-semibold">Templates</h2>
          <a href="/templates" class="text-sm font-medium no-underline">View all</a>
        </div>
        <div class="space-y-4">
          {
            featuredTemplates.map((template) => (
              <ArticleCard
                title={template.data.title}
                href={contentPath('templates', slugFromEntry(template))}
                summary={template.data.summary}
                category={template.data.category}
              />
            ))
          }
        </div>
      </div>

      <div>
        <div class="mb-4 flex items-center justify-between">
          <h2 class="text-xl font-semibold">Tools</h2>
          <a href="/tools" class="text-sm font-medium no-underline">View all</a>
        </div>
        <div class="space-y-4">
          {
            featuredTools.map((tool) => (
              <ArticleCard
                title={tool.data.title}
                href={contentPath('tools', slugFromEntry(tool))}
                summary={tool.data.summary}
                category={tool.data.category}
              />
            ))
          }
        </div>
      </div>
    </section>

    <section class="mt-12">
      <CTABox
        title="Planning a condo vote or AGM?"
        description="Explore digital voting resources when your corporation is evaluating electronic participation options."
        href="/guides/electronic-voting-ontario-condos"
      />
    </section>

    <DisclaimerBox />
  </div>
</BaseLayout>
